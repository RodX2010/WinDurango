        SpeechGrammar AddGrammarFromUri(String key, Windows.Foundation.Uri grammarUri);
        SpeechGrammar AddGrammarFromStream(String key, Windows.Storage.Streams.IRandomAccessStream stream);
        void Clear();
        SpeechGrammar Remove(String key);
        SpeechGrammar AddGrammarFromBuilder(String key, SpeechGrammarBuilder grammar);
    };

