namespace Windows.Xbox.Speech.Recognition
{

    enum SpeechGrammarProbability
    {
        Low = 0,
        Medium = 1,
        High = 2
    };

    enum ContinuousSpeechRecognitionStatus
    {
        InProgress = 0,
        Paused = 1,
        Stopped = 2,
        Completed = 3,
        Error = 4
    };

    enum SpeechGraphStateType
    {
        Transitional = 0,
        Final = 1
    };

    enum SpeechGrammarRuleInclusionMode
    {
        AllRules = 0,
        OnlyEnabledRules = 1
    };

    enum SpeechPronunciationFormat
    {
        MicrosoftUniversalPhoneSet = 0,
        InternationalPhoneticAlphabet = 1,
        MicrosoftSapiPhoneSet = 2
    };

    enum SpeechPronunciationSource
    {
        SpeechRecognizerLexicon = 0,
        SpeechRecognizerLetterToSound = 1,
        ExternalGrammarInline = 2,
        ExternalLexicon = 3
    };

    enum SpeechRecognitionConfidence
    {
        Rejected = 0,
        Low = 1,
        Medium = 2,
        High = 3
    };

    enum SpeechRecognitionAudioProblem
    {
        None = 0,
        TooNoisy = 1,
        NoSignal = 2,
        TooLoud = 3,
        TooQuiet = 4,
        TooFast = 5,
        TooSlow = 6
    };

    enum SpeechRecognizerAudioCaptureState
    {
        Inactive = 0,
        Capturing = 1
    };

    enum SpeechGrammarBuilderSemanticsFormat
    {
        Literal = 0,
        EcmaScript = 1
    };

    enum SpeechRuleItemMatchType
    {
        Required = 0,
        Optional = 1
    };

    enum SpeechPhraseSubsetMatchMode
    {
        AllWords = 0,
        Subsequence = 1,
        OrderedSubset = 2,
        SubsequenceContentRequired = 3,
        OrderedSubsetContentRequired = 4
    };

    [uuid(3A3AA19C-F4E9-4985-A53C-DBCC22795CA7)]
    [version(0x00010000)]
    interface ISpeechRecognizer
        requires Windows.Foundation.IClosable
    {
        Windows.Foundation.IAsyncOperation<SpeechRecognitionResult> RecognizeAsync();
        Windows.Foundation.IAsyncAction PreloadGrammarsAsync();

        SpeechRecognizerSettings Settings{ get; };
        SpeechGrammarSet Grammars{ get; };

        void StartContinuousRecognition();
        void StopContinuousRecognition();
        void ResumeContinuousRecognition();

        Boolean PauseOnContinuousRecognitionResultAvailable;

        SpeechRecognizerInformation GetRecognizer();
        void SetRecognizer(SpeechRecognizerInformation recognizerInformation);

        event Windows.Foundation.TypedEventHandler<SpeechRecognizer, SpeechAudioProblemOccurredEventArgs> AudioProblemOccurred;
        event Windows.Foundation.TypedEventHandler<SpeechRecognizer, SpeechRecognizerAudioCaptureStateChangedEventArgs> AudioCaptureStateChanged;
        event Windows.Foundation.TypedEventHandler<SpeechRecognizer, ContinuousSpeechRecognitionResultEventArgs> ContinuousRecognitionResultAvailable;
        event Windows.Foundation.TypedEventHandler<SpeechRecognizer, ContinuousSpeechRecognitionStatusEventArgs> ContinuousRecognitionStatusChanged;
        event Windows.Foundation.TypedEventHandler<SpeechRecognizer, SpeechHypothesisResultEventArgs> HypothesisAvailable;
        event Windows.Foundation.TypedEventHandler<SpeechRecognizer, SpeechRecognizerSoundStartedEventArgs> SoundStarted;
        event Windows.Foundation.TypedEventHandler<SpeechRecognizer, SpeechRecognizerSoundEndedEventArgs> SoundEnded;
        event Windows.Foundation.TypedEventHandler<SpeechRecognizer, SpeechRecognizerPhraseStartedEventArgs> PhraseStarted;
    };

