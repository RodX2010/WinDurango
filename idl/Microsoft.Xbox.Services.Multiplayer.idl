    {
        Unknown,
        None,
        Local,
        Followed,
    };

    enum MultiplayerSessionStatus
    {
        Unknown,
        Active,
        Inactive,
        Reserved,
    };

    enum MultiplayerSessionVisibility
    {
        Unknown,
        Any,
        Private,
        Visible,
        Full,
        Open,
    };

    enum MultiplayerSessionWriteMode
    {
        CreateNew,
        UpdateOrCreateNew,
        UpdateExisting,
        SynchronizedUpdate,
    };

    enum MultiplayMetrics
    {
        Unknown,
        BandwidthUp,
        BandwidthDown,
        Bandwidth,
        Latency,
    };

    enum MutableRoleSetting
    {
        Max,
        Target,
    };

    enum NetworkAddressTranslationSetting
    {
        Unknown,
        Open,
        Moderate,
        Strict,
    };

    enum WriteSessionStatus
    {
        Unknown,
        AccessDenied,
        Created,
        Conflict,
        HandleNotFound,
        OutOfSync,
        SessionDeleted,
        Updated,
    };

