    enum MultiplayerInitializationStage
    {
        Unknown,
        None,
        Joining,
        Measuring,
        Evaluating,
        Failed,
    };

    enum MultiplayerMeasurementFailure
    {
        Unknown,
        None,
        Timeout,
        Latency,
        BandwidthUp,
        BandwidthDown,
        Group,
        Network,
        Episode,
    };

    enum MultiplayerSessionChangeTypes
    {
        None = 0,
        Everything = 1,
        HostDeviceTokenChange = 2,
        InitializationStateChange = 4,
